{
  "root": "card-main",
  "state": {},
  "elements": {
    "card-main": {
      "type": "Card",
      "props": {
        "title": "mine-bean"
      },
      "children": [
        "stack-content"
      ]
    },
    "stack-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "text-session",
        "stack-stats",
        "sep-1",
        "text-tx",
        "alert-rpc"
      ]
    },
    "text-session": {
      "type": "Text",
      "props": {
        "text": "Session complete"
      }
    },
    "stack-stats": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "lg"
      },
      "children": [
        "stat-deploy",
        "stat-skipped"
      ]
    },
    "stat-deploy": {
      "type": "Stat",
      "props": {
        "label": "Deployed",
        "value": "1"
      }
    },
    "stat-skipped": {
      "type": "Stat",
      "props": {
        "label": "Skipped",
        "value": "4"
      }
    },
    "sep-1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "text-tx": {
      "type": "Text",
      "props": {
        "text": "TX: 0x0a8839eaa9cc27715a1c88100efedd0ff4bf1e7947343b30269dcddeca1a364a"
      }
    },
    "alert-rpc": {
      "type": "Alert",
      "props": {
        "title": "Pending rewards unknown",
        "message": "RPC issues",
        "type": "warning"
      }
    }
  }
}
